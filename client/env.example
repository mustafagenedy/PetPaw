# Client environment — copy to `.env.local` for dev, set the real values in
# Vercel → Project Settings → Environment Variables for prod / preview.
#
# Vite ONLY exposes vars prefixed with VITE_ to the bundle.

# API origin. Leave unset in dev (Vite proxies /api → localhost:5000).
# In prod set to the server URL, e.g. https://petpaw-api.onrender.com
# VITE_API_URL=

# Sentry DSN (browser project) — leave unset to disable client-side error tracking.
# VITE_SENTRY_DSN=https://<key>@oXXXX.ingest.sentry.io/XXXX
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Plausible / Umami analytics. Set VITE_PLAUSIBLE_DOMAIN to your site's
# registered domain to inject the analytics script.
# Optionally override VITE_PLAUSIBLE_SRC (default https://plausible.io/js/script.js)
# to point at a self-hosted Plausible or an Umami install.
# VITE_PLAUSIBLE_DOMAIN=petpaw.com
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js
