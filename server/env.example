# Database Configuration
MONGO_URI=mongodb://localhost:27017/petpaw

# JWT Configuration
# Generate a strong secret with: openssl rand -base64 32
# MUST be at least 32 characters. Do NOT ship the placeholder below.
JWT_SECRET=REPLACE_ME_WITH_A_32_BYTE_RANDOM_SECRET

# Server Configuration
PORT=5000

# CORS: comma-separated list of origins the API accepts requests from
# Dev: http://localhost:5173
# Prod: https://your-client-domain.com (add more comma-separated if you have staging)
CORS_ORIGIN=http://localhost:5173

# Cookie SameSite policy
# - "lax" (default) when client + API are same-site (e.g. petpaw.com + api.petpaw.com)
# - "none" when client + API are cross-site (e.g. vercel.app + onrender.com)
#    → requires HTTPS (NODE_ENV=production sets Secure automatically)
COOKIE_SAMESITE=lax

# Admin bootstrap (used by addAdmin.js only, not the running server)
# ADMIN_EMAIL=owner@example.com
# ADMIN_PASSWORD=a-strong-passphrase-of-at-least-12-chars
# ADMIN_NAME=Admin

# Production
# NODE_ENV=production
